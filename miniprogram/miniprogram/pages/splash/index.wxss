/* ════════════════════════════════════════
   KXT 日报 — 启动页样式
   ════════════════════════════════════════ */

.splash {
  position: relative;
  min-height: 100vh;
  background: linear-gradient(168deg, #1a0e08 0%, #2a1a12 45%, #1a0e08 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

/* ── 背景光晕 ─────────────────────── */
.bg-glow {
  position: absolute;
  border-radius: 50%;
  filter: blur(90rpx);
  opacity: 0.35;
  pointer-events: none;
}
.g1 { width: 520rpx; height: 520rpx; background: #c96342; top: -120rpx; left: -80rpx; }
.g2 { width: 400rpx; height: 400rpx; background: #e8855a; bottom: -60rpx; right: -40rpx; }
.g3 { width: 300rpx; height: 300rpx; background: #fdf0eb; top: 50%; left: 50%; transform: translate(-50%,-50%); }

/* ── 表情组 ────────────────────────── */
.emoji-wrap {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 240rpx;
  height: 240rpx;
  margin-bottom: 48rpx;
  transition: transform 0.18s ease;
}
.emoji-wrap.pressed {
  transform: scale(0.92);
}
.emoji {
  position: absolute;
  font-size: 72rpx;
  opacity: 0.85;
}
.e1 { top: 0;     left: 50%; transform: translateX(-50%); }
.e2 { top: 50%;  right: 0;  transform: translateY(-50%); }
.e3 { bottom: 0; left: 50%; transform: translateX(-50%); }
.e4 { top: 50%;  left: 0;   transform: translateY(-50%); }

.center-ring {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 3rpx solid rgba(201,99,66,0.45);
  box-shadow: 0 0 40rpx rgba(201,99,66,0.25);
}

/* ── 品牌文字 ─────────────────────── */
.brand {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 64rpx;
}
.brand-name {
  font-size: 52rpx;
  font-weight: 700;
  color: #fdfaf8;
  letter-spacing: 4rpx;
  text-shadow: 0 2rpx 24rpx rgba(201,99,66,0.35);
}
.brand-sub {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: rgba(253,250,248,0.45);
  letter-spacing: 6rpx;
}

/* ── 加载状态 ─────────────────────── */
.status-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
  min-height: 80rpx;
}
.dots {
  display: flex;
  gap: 14rpx;
}
.d {
  width: 14rpx; height: 14rpx;
  border-radius: 50%;
  background: rgba(201,99,66,0.75);
}
.d1 { animation: blink 1.4s ease-in-out infinite; }
.d2 { animation: blink 1.4s ease-in-out 0.22s infinite; }
.d3 { animation: blink 1.4s ease-in-out 0.44s infinite; }

@keyframes blink {
  0%, 80%, 100% { opacity: 0.25; transform: scale(0.75); }
  40%            { opacity: 1;    transform: scale(1.25); }
}

.status-txt {
  font-size: 26rpx;
  color: rgba(250,247,244,0.45);
  letter-spacing: 1rpx;
}

/* ── 重试区域 ─────────────────────── */
.retry-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
  animation: fade-in 0.5s ease;
}
.retry-btn {
  width: 280rpx;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 40rpx;
  background: rgba(201,99,66,0.85);
  color: #fdfaf8;
  font-size: 28rpx;
  text-align: center;
  border: none;
}
.retry-btn::after {
  border: none;
}
.retry-btn:active {
  background: rgba(201,99,66,1);
}
.retry-hint {
  font-size: 22rpx;
  color: rgba(250,247,244,0.35);
  text-align: center;
  line-height: 1.6;
  white-space: pre-line;
}

/* ── 点按提示 ─────────────────────── */
.tap-hint {
  position: absolute;
  bottom: 80rpx;
  font-size: 24rpx;
  color: rgba(250,247,244,0.25);
  letter-spacing: 2rpx;
  animation: fade-in 1s ease 2s both;
}

@keyframes fade-in {
  from { opacity: 0; transform: translateY(12rpx); }
  to   { opacity: 1; transform: translateY(0); }
}
