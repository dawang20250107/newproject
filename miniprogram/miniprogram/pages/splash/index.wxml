<view class="splash" bindtap="onTapSplash">
  <!-- 背景光晕 -->
  <view class="bg-glow g1"></view>
  <view class="bg-glow g2"></view>
  <view class="bg-glow g3"></view>

  <!-- 表情组 -->
  <view class="emoji-wrap {{pressed ? 'pressed' : ''}}">
    <text class="emoji e1">😊</text>
    <text class="emoji e2">✨</text>
    <text class="emoji e3">📝</text>
    <text class="emoji e4">🌟</text>
    <view class="center-ring"></view>
  </view>

  <!-- 品牌文字 -->
  <view class="brand">
    <view class="brand-name">KXT 日报</view>
    <view class="brand-sub">记录每一天的成长</view>
  </view>

  <!-- 加载状态 -->
  <view class="status-area">
    <view class="dots" wx:if="{{!showRetryBtn}}">
      <view class="d d1"></view>
      <view class="d d2"></view>
      <view class="d d3"></view>
    </view>
    <text class="status-txt">{{statusText}}</text>
  </view>

  <!-- 重试按钮 -->
  <view wx:if="{{showRetryBtn}}" class="retry-area">
    <button class="retry-btn" bindtap="onTapRetry">点此重试</button>
    <text class="retry-hint">请确认网络通畅后重试\n或联系管理员检查服务器域名配置</text>
  </view>

  <!-- 点按提示 -->
  <view class="tap-hint">轻触任意处加速</view>
</view>
