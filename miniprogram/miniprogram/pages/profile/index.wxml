<import src="../../templates/tapfx.wxml" />
<view class="page" capture-bind:touchstart="onTapFx">

  <!-- 头像卡 -->
  <view class="card avatar-card">
    <button class="avatar-btn" open-type="chooseAvatar" bind:chooseavatar="onChooseAvatar">
      <image wx:if="{{avatar}}" class="avatar-img" src="{{avatar}}" mode="aspectFill" />
      <view wx:else class="avatar">
        <text class="avatar-char">{{avatarChar}}</text>
      </view>
    </button>
    <view class="avatar-info">
      <view class="avatar-name">{{name || display_name || '未设置姓名'}}</view>
      <view class="avatar-sub">{{dept || '部门未填写'}} · {{role || '岗位未填写'}}</view>
      <view class="avatar-hint">点击头像 · 同步微信头像</view>
    </view>
  </view>

  <!-- 资料卡 -->
  <view class="card">
    <view class="row" style="gap:10rpx;margin-bottom:28rpx">
      <text style="font-size:30rpx">✏️</text>
      <text class="section-title">个人资料</text>
    </view>

    <view class="field">
      <text class="label">姓名</text>
      <input class="input" placeholder="请填写姓名（用于日报水印）"
        value="{{name}}" data-field="name" bindinput="onInput" />
    </view>
    <view class="field">
      <text class="label">微信昵称</text>
      <input class="input" placeholder="选填"
        value="{{display_name}}" data-field="display_name" bindinput="onInput" />
    </view>
    <view class="field">
      <text class="label">部门</text>
      <input class="input" placeholder="请填写所在部门"
        value="{{dept}}" data-field="dept" bindinput="onInput" />
    </view>
    <view class="field" style="margin-bottom:0">
      <text class="label">岗位</text>
      <input class="input" placeholder="请填写当前岗位"
        value="{{role}}" data-field="role" bindinput="onInput" />
    </view>
  </view>

  <!-- 说明 -->
  <view class="tip-card">
    <text class="tip-icon">💡</text>
    <text class="tip-text">资料将用于日报水印和 AI 分析的个性化称呼</text>
  </view>

  <!-- 浮动保存卡（仅有改动时出现） -->
  <view wx:if="{{isDirty}}" class="save-float">
    <view class="save-float-info">
      <text class="save-float-dot">●</text>
      <text class="save-float-txt">资料有改动，记得保存</text>
    </view>
    <button class="btn save-float-btn" disabled="{{isSaving}}" bindtap="onSave">
      {{isSaving?'保存中…':'保存'}}
    </button>
  </view>

  <!-- 手指点击特效 -->
  <template is="tapfx" data="{{sparks: tapSparks}}" />

</view>
