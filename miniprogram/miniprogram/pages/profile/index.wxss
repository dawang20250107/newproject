.page { padding-bottom: 140rpx; background: #faf7f4; }

/* ── 头像卡 ───────────────────────────── */
.avatar-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 36rpx 36rpx;
  background: linear-gradient(135deg, rgba(255,253,250,0.95), rgba(253,240,235,0.90));
}

.avatar-wrap {
  position: relative;
  margin-bottom: 24rpx;
}
.avatar {
  width: 120rpx; height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #c96342, #e8855a);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 30rpx rgba(201, 99, 66, 0.35);
}
.avatar-char {
  font-size: 48rpx;
  font-weight: 700;
  color: #fff;
}
.avatar-glow {
  position: absolute;
  top: 0; left: 0;
  width: 120rpx; height: 120rpx;
  border-radius: 50%;
  background: rgba(201, 99, 66, 0.15);
  animation: glow-ring 2.5s ease-in-out infinite;
}
@keyframes glow-ring {
  0%, 100% { transform: scale(1.0); opacity: 0.6; }
  50%       { transform: scale(1.25); opacity: 0; }
}

.avatar-info { text-align: center; }
.avatar-name {
  font-size: 34rpx;
  font-weight: 700;
  color: #1a1208;
  margin-bottom: 10rpx;
}
.avatar-sub {
  font-size: 24rpx;
  color: #9b8070;
  letter-spacing: 1rpx;
}

/* ── section 标题 ─────────────────────── */
.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1a1208;
}

/* ── 字段 ─────────────────────────────── */
.field { margin-bottom: 28rpx; }
.field .label {
  display: block;
  margin-bottom: 14rpx;
}
.input {
  width: 100%;
  background: rgba(250, 240, 235, 0.50);
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  color: #1a1208;
  border: 1rpx solid rgba(201, 99, 66, 0.10);
}
.input:focus {
  border-color: rgba(201, 99, 66, 0.30);
  background: rgba(255, 255, 253, 0.80);
}

/* ── 提示条 ───────────────────────────── */
.tip-card {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin: 0 24rpx 16rpx;
  padding: 18rpx 24rpx;
  background: #fdf0eb;
  border-radius: 14rpx;
  border: 1rpx solid rgba(201, 99, 66, 0.15);
}
.tip-icon { font-size: 28rpx; }
.tip-text { font-size: 24rpx; color: #9b8070; line-height: 1.5; flex: 1; }

/* ── 保存栏 ───────────────────────────── */
.save-bar {
  position: fixed;
  bottom: 0; left: 0; right: 0;
  background: rgba(253, 250, 248, 0.93);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-top: 1rpx solid rgba(180, 100, 60, 0.10);
  padding: 20rpx 28rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  z-index: 200;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
}
.save-status { font-size: 24rpx; }
.status-dirty { color: #c96342; }
.status-ok    { color: #9b8070; }
