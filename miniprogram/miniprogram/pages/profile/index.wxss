.page { padding-bottom: 140rpx; background: #e8e0d8; }

/* ── 头像卡 ───────────────────────────── */
.avatar-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 36rpx 36rpx;
  background: linear-gradient(135deg, rgba(255,253,250,0.95), rgba(253,240,235,0.90));
}

.avatar-wrap {
  position: relative;
  margin-bottom: 24rpx;
  width: 140rpx; height: 140rpx;
}
.avatar-btn {
  position: relative;
  width: 140rpx; height: 140rpx;
  padding: 0;
  margin: 0;
  background: transparent;
  border: none;
  line-height: normal;
  border-radius: 50%;
  overflow: visible;
}
.avatar-btn::after { border: none; }
.avatar, .avatar-img {
  width: 140rpx; height: 140rpx;
  border-radius: 50%;
  box-shadow: 0 8rpx 30rpx rgba(201, 99, 66, 0.35);
}
.avatar {
  background: linear-gradient(135deg, #c96342, #e8855a);
  display: flex;
  align-items: center;
  justify-content: center;
}
.avatar-char {
  font-size: 56rpx;
  font-weight: 700;
  color: #fff;
}
.avatar-edit-badge {
  position: absolute;
  right: -4rpx; bottom: -4rpx;
  width: 48rpx; height: 48rpx;
  border-radius: 50%;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.15);
  border: 2rpx solid rgba(201, 99, 66, 0.20);
}
.avatar-glow {
  position: absolute;
  top: 0; left: 0;
  width: 140rpx; height: 140rpx;
  border-radius: 50%;
  background: rgba(201, 99, 66, 0.15);
  animation: glow-ring 2.5s ease-in-out infinite;
  pointer-events: none;
}
@keyframes glow-ring {
  0%, 100% { transform: scale(1.0); opacity: 0.6; }
  50%       { transform: scale(1.25); opacity: 0; }
}

.avatar-info { text-align: center; }
.avatar-name {
  font-size: 38rpx;
  font-weight: 700;
  color: #1a1208;
  margin-bottom: 10rpx;
}
.avatar-sub {
  font-size: 26rpx;
  color: #9b8070;
  letter-spacing: 1rpx;
}
.avatar-hint {
  margin-top: 14rpx;
  font-size: 22rpx;
  color: #c96342;
  background: rgba(201, 99, 66, 0.08);
  border-radius: 20rpx;
  padding: 6rpx 20rpx;
  display: inline-block;
}

/* ── section 标题 ─────────────────────── */
.section-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1a1208;
}

/* ── 字段 ─────────────────────────────── */
.field { margin-bottom: 30rpx; }
.field .label {
  display: block;
  margin-bottom: 14rpx;
}
.input {
  width: 100%;
  background: rgba(250, 240, 235, 0.50);
  border-radius: 14rpx;
  padding: 26rpx 24rpx;
  font-size: 32rpx;
  box-sizing: border-box;
  min-height: 88rpx;
  color: #1a1208;
  border: 1rpx solid rgba(201, 99, 66, 0.10);
}
.input:focus {
  border-color: rgba(201, 99, 66, 0.30);
  background: rgba(255, 255, 253, 0.80);
}

/* ── 提示条 ───────────────────────────── */
.tip-card {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin: 0 24rpx 16rpx;
  padding: 18rpx 24rpx;
  background: #fdf0eb;
  border-radius: 14rpx;
  border: 1rpx solid rgba(201, 99, 66, 0.15);
}
.tip-icon { font-size: 28rpx; }
.tip-text { font-size: 24rpx; color: #9b8070; line-height: 1.5; flex: 1; }

/* ── 浮动保存卡（仅有改动时出现） ──────── */
.save-float {
  position: fixed;
  left: 24rpx; right: 24rpx;
  bottom: calc(32rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 254, 0.98);
  border: 1rpx solid rgba(255, 255, 255, 0.95);
  border-radius: 24rpx;
  padding: 22rpx 24rpx 22rpx 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow:
    0 12rpx 44rpx rgba(180, 100, 60, 0.22),
    0 2rpx 10rpx rgba(0, 0, 0, 0.08),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.9);
  z-index: 200;
  animation: save-float-in 0.35s cubic-bezier(0.25, 1.2, 0.4, 1) both;
}
@keyframes save-float-in {
  from { opacity: 0; transform: translateY(40rpx) scale(0.96); }
  to   { opacity: 1; transform: translateY(0) scale(1); }
}
.save-float-info {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.save-float-dot {
  color: #c96342;
  font-size: 20rpx;
  animation: dot-pulse 1.4s ease-in-out infinite;
}
@keyframes dot-pulse {
  0%, 100% { opacity: 1; }
  50%       { opacity: 0.3; }
}
.save-float-txt {
  font-size: 28rpx;
  color: #6b5347;
  font-weight: 500;
}
.save-float-btn {
  padding: 18rpx 48rpx;
  font-size: 30rpx;
  border-radius: 14rpx;
}
