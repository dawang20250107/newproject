/* ══════════════════════════════════════════
   Report Page — Notion × Claude paper style
   ══════════════════════════════════════════ */

.page {
  padding-bottom: 140rpx;
  background: #faf7f4;
}

/* ── Tab 栏（毛玻璃吸顶） ───────────────── */
.tabs {
  display: flex;
  position: sticky;
  top: 0;
  z-index: 100;
  background: rgba(250, 247, 244, 0.92);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-bottom: 1rpx solid rgba(180, 100, 60, 0.10);
}
.tab {
  flex: 1;
  text-align: center;
  padding: 28rpx 0 22rpx;
  font-size: 28rpx;
  color: #9b8070;
  position: relative;
  transition: color 0.25s ease;
}
.tab.active {
  color: #c96342;
  font-weight: 700;
}
.tab.active::after {
  content: '';
  position: absolute;
  bottom: 0; left: 18%; width: 64%;
  height: 4rpx;
  border-radius: 2rpx;
  background: linear-gradient(90deg, #c96342, #e8855a);
}

/* ── 日期卡 ───────────────────────────── */
.date-card { padding: 24rpx 36rpx; }
.date-pill {
  padding: 12rpx 28rpx;
  background: #fdf0eb;
  border-radius: 40rpx;
  border: 1rpx solid rgba(201, 99, 66, 0.25);
  color: #c96342;
  font-size: 28rpx;
  font-weight: 600;
  letter-spacing: 1rpx;
}

/* ── Section 标题 ─────────────────────── */
.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1a1208;
}

/* ── 空状态 ───────────────────────────── */
.empty-hint {
  padding: 36rpx;
  text-align: center;
  color: #c5a090;
  font-size: 26rpx;
}

/* ── 时段块 ───────────────────────────── */
.block-card {
  background: rgba(250, 240, 235, 0.45);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid rgba(201, 99, 66, 0.10);
}

/* 时段时间 */
.time-pill {
  padding: 10rpx 22rpx;
  background: #fff;
  border-radius: 12rpx;
  border: 1rpx solid rgba(180, 100, 60, 0.18);
  font-size: 26rpx;
  color: #c96342;
  font-weight: 600;
}
.time-sep {
  color: #c5a090;
  font-size: 24rpx;
  margin: 0 4rpx;
}

/* 全完成 & 删除 */
.done-all-btn {
  font-size: 22rpx;
  color: #fff;
  background: linear-gradient(135deg, #3aa856, #5ec875);
  padding: 8rpx 18rpx;
  border-radius: 8rpx;
  font-weight: 600;
  box-shadow: 0 2rpx 8rpx rgba(58, 168, 86, 0.30);
}
.done-all-btn:active { transform: scale(0.92); }
.del-btn {
  font-size: 22rpx;
  color: #e06060;
  padding: 8rpx 16rpx;
}

/* ── 任务行 ───────────────────────────── */
.task-row {
  display: flex;
  align-items: flex-start;
  margin-bottom: 16rpx;
  background: rgba(255, 255, 253, 0.80);
  border-radius: 12rpx;
  padding: 18rpx 16rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.90);
}

/* 完成圆圈 */
.task-check {
  width: 44rpx; height: 44rpx;
  min-width: 44rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(201, 99, 66, 0.35);
  margin-right: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
  margin-top: 4rpx;
}
.task-check.done {
  background: linear-gradient(135deg, #c96342, #e8855a);
  border-color: transparent;
  box-shadow: 0 2rpx 10rpx rgba(201, 99, 66, 0.35);
  animation: pop-in 0.25s ease;
}
.check-icon {
  color: #fff;
  font-size: 24rpx;
  font-weight: 700;
}

@keyframes pop-in {
  0%   { transform: scale(0.6); }
  70%  { transform: scale(1.15); }
  100% { transform: scale(1); }
}

.task-body { flex: 1; }

.task-input {
  font-size: 28rpx;
  color: #1a1208;
  padding: 4rpx 0;
  border-bottom: 1rpx solid rgba(180, 100, 60, 0.10);
  line-height: 1.5;
}
.task-input.done-text {
  color: #c5a090;
  text-decoration: line-through;
}

/* 进度滑块 */
.task-slider {
  flex: 1;
  margin: 0 8rpx 0 0 !important;
}
.progress-val {
  font-size: 22rpx;
  color: #c96342;
  font-weight: 600;
  min-width: 60rpx;
  text-align: right;
}
.del-sm {
  color: #e09090;
  font-size: 24rpx;
  padding: 0 0 0 16rpx;
}

.add-task-btn {
  font-size: 24rpx;
  color: #c96342;
  padding: 10rpx 4rpx;
  opacity: 0.75;
}
.add-task-btn:active { opacity: 1; }

/* ── 复盘区 ───────────────────────────── */
.field {
  margin-bottom: 28rpx;
}
.field .label {
  display: block;
  margin-bottom: 14rpx;
}
.textarea, .input {
  width: 100%;
  background: rgba(250, 240, 235, 0.50);
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  min-height: 64rpx;
  color: #1a1208;
  border: 1rpx solid rgba(201, 99, 66, 0.10);
  line-height: 1.6;
}
.textarea:focus, .input:focus {
  border-color: rgba(201, 99, 66, 0.30);
  background: rgba(255, 255, 253, 0.80);
}

/* ── 保存栏（毛玻璃） ─────────────────── */
.save-bar {
  position: fixed;
  bottom: 0; left: 0; right: 0;
  background: rgba(253, 250, 248, 0.93);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-top: 1rpx solid rgba(180, 100, 60, 0.10);
  padding: 20rpx 28rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  z-index: 200;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
}
.save-status { font-size: 24rpx; }
.status-dirty { color: #c96342; }
.status-ok    { color: #3aa856; }
.status-idle  { color: #c5a090; }

.save-actions { display: flex; gap: 16rpx; align-items: center; }

.btn-xs {
  padding: 10rpx 18rpx !important;
  font-size: 22rpx !important;
}

.all-done-btn {
  position: relative;
  overflow: hidden;
}
.all-done-btn.glowing {
  box-shadow: 0 0 20rpx rgba(201, 99, 66, 0.45);
  animation: glow-pulse 1.5s ease-in-out infinite;
}
@keyframes glow-pulse {
  0%, 100% { box-shadow: 0 0 12rpx rgba(201, 99, 66, 0.30); }
  50%       { box-shadow: 0 0 28rpx rgba(201, 99, 66, 0.55); }
}

/* ── 日历 ─────────────────────────────── */
.cal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}
.cal-title { font-size: 30rpx; font-weight: 700; }
.cal-nav {
  font-size: 44rpx;
  color: #c96342;
  padding: 0 24rpx;
  line-height: 1;
}
.cal-nav:active { opacity: 0.6; }

.cal-week, .cal-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
}
.cal-w {
  text-align: center;
  padding: 12rpx 0;
  color: #9b8070;
  font-size: 22rpx;
  font-weight: 600;
  letter-spacing: 1rpx;
}
.cal-cell {
  position: relative;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #1a1208;
}
.cal-cell.empty { color: transparent; }
.cal-cell.today {
  background: #fdf0eb;
  color: #c96342;
  border-radius: 50%;
  font-weight: 700;
  box-shadow: 0 2rpx 10rpx rgba(201, 99, 66, 0.20);
}
.cal-cell:active { opacity: 0.6; }
.cal-dot {
  position: absolute;
  bottom: 8rpx;
  width: 10rpx; height: 10rpx;
  border-radius: 50%;
  background: #c96342;
}

.cal-hint {
  margin: -4rpx 24rpx 24rpx;
  padding: 16rpx 20rpx;
  background: #fdf0eb;
  border-radius: 12rpx;
  color: #c96342;
  font-size: 24rpx;
  text-align: center;
  border: 1rpx solid rgba(201, 99, 66, 0.15);
}

/* ── 周分析 ───────────────────────────── */
.stat-card { background: linear-gradient(135deg, rgba(255,253,250,0.95), rgba(253,240,235,0.90)); }

.week-range {
  font-size: 24rpx;
  color: #9b8070;
  text-align: center;
  margin-bottom: 24rpx;
  letter-spacing: 1rpx;
}
.week-stat-row {
  display: flex;
  align-items: center;
  margin-bottom: 32rpx;
}
.stat-box {
  flex: 1;
  text-align: center;
}
.stat-num {
  font-size: 56rpx;
  font-weight: 800;
  color: #c96342;
  line-height: 1.1;
  letter-spacing: -1rpx;
}
.stat-lbl {
  font-size: 22rpx;
  color: #9b8070;
  margin-top: 8rpx;
  letter-spacing: 1rpx;
}
.stat-divider {
  width: 1rpx;
  height: 80rpx;
  background: rgba(201, 99, 66, 0.15);
}

/* AI 分析按钮组 */
.ai-btn-row {
  display: flex;
  gap: 16rpx;
}
.ai-btn {
  flex: 2;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  padding: 22rpx 0;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #c96342, #e8855a);
  color: #fff;
  font-size: 26rpx;
  font-weight: 700;
  box-shadow: 0 4rpx 16rpx rgba(201, 99, 66, 0.32);
  letter-spacing: 1rpx;
}
.ai-btn:active { transform: scale(0.94); }
.ai-btn.loading { opacity: 0.7; }
.ai-btn-secondary {
  flex: 1;
  background: rgba(201, 99, 66, 0.10);
  color: #c96342;
  box-shadow: none;
  border: 1rpx solid rgba(201, 99, 66, 0.25);
  font-size: 24rpx;
}
.ai-icon { font-size: 28rpx; }

/* 日详情行 */
.day-row {
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(180, 100, 60, 0.08);
}
.day-row:last-child { border-bottom: none; }
.day-row.has-data { }
.day-row:active { opacity: 0.7; }

.day-head {
  display: flex;
  align-items: center;
}
.day-lbl {
  width: 80rpx;
  color: #1a1208;
  font-weight: 700;
  font-size: 28rpx;
}
.day-date { color: #9b8070; font-size: 24rpx; flex: 1; }
.day-hrs  { color: #c96342; font-weight: 700; font-size: 28rpx; }
.day-empty { color: #d4bbb0; }

.day-tasks {
  margin-top: 12rpx;
  padding-left: 80rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

/* ══════════════ AI 分析弹窗 ══════════════ */
.modal-overlay {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(26, 18, 8, 0.55);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  z-index: 999;
  display: flex;
  align-items: flex-end;
}

.modal-card {
  width: 100%;
  max-height: 82vh;
  background: rgba(255, 255, 253, 0.97);
  border-radius: 32rpx 32rpx 0 0;
  padding: 0 0 env(safe-area-inset-bottom);
  display: flex;
  flex-direction: column;
  box-shadow: 0 -8rpx 60rpx rgba(0, 0, 0, 0.18);
  animation: slide-up 0.35s cubic-bezier(0.25, 0.8, 0.25, 1) both;
}

@keyframes slide-up {
  from { transform: translateY(100%); }
  to   { transform: translateY(0); }
}

.modal-handle {
  width: 80rpx; height: 8rpx;
  background: rgba(180, 100, 60, 0.20);
  border-radius: 4rpx;
  margin: 20rpx auto 0;
}
.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 36rpx 12rpx;
}
.modal-title {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 32rpx;
  font-weight: 700;
  color: #1a1208;
}
.modal-icon { font-size: 36rpx; }
.modal-close {
  width: 56rpx; height: 56rpx;
  border-radius: 50%;
  background: rgba(180, 100, 60, 0.10);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #9b8070;
}
.modal-close:active { background: rgba(180, 100, 60, 0.20); }

.modal-range {
  padding: 0 36rpx 20rpx;
  font-size: 22rpx;
  color: #9b8070;
  border-bottom: 1rpx solid rgba(180, 100, 60, 0.08);
}

/* 加载中 */
.modal-loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
  gap: 24rpx;
}
.loading-dots { display: flex; gap: 12rpx; }
.ld {
  width: 16rpx; height: 16rpx;
  border-radius: 50%;
  background: rgba(201, 99, 66, 0.70);
}
.ld1 { animation: blink-ld 1.3s ease-in-out infinite; }
.ld2 { animation: blink-ld 1.3s ease-in-out 0.2s infinite; }
.ld3 { animation: blink-ld 1.3s ease-in-out 0.4s infinite; }
@keyframes blink-ld {
  0%, 80%, 100% { opacity: 0.2; transform: scale(0.75); }
  40%            { opacity: 1;   transform: scale(1.25); }
}
.loading-txt {
  font-size: 26rpx;
  color: #9b8070;
}

/* 结果文字 */
.modal-body {
  flex: 1;
  max-height: 55vh;
  padding: 24rpx 36rpx;
}
.analysis-text {
  font-size: 28rpx;
  color: #1a1208;
  line-height: 1.8;
  white-space: pre-wrap;
  word-break: break-word;
}

/* 底部操作 */
.modal-footer {
  padding: 20rpx 36rpx 28rpx;
  border-top: 1rpx solid rgba(180, 100, 60, 0.08);
}
.modal-copy-btn {
  width: 100%;
  padding: 24rpx;
  font-size: 30rpx;
  letter-spacing: 2rpx;
  border-radius: 20rpx;
}

/* 周报一键复制汇报按钮 */
.copy-week-btn {
  margin-top: 20rpx;
  padding: 20rpx;
  text-align: center;
  font-size: 26rpx;
  color: #c96342;
  background: rgba(201, 99, 66, 0.08);
  border: 1rpx solid rgba(201, 99, 66, 0.20);
  border-radius: 16rpx;
  font-weight: 600;
  letter-spacing: 1rpx;
}
.copy-week-btn:active { background: rgba(201, 99, 66, 0.15); }
