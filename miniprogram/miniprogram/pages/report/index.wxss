.page { padding-bottom: 120rpx; }

.tabs {
  display: flex;
  background: #fff;
  border-bottom: 2rpx solid #eee;
  position: sticky;
  top: 0;
  z-index: 10;
}
.tab {
  flex: 1;
  text-align: center;
  padding: 28rpx 0;
  font-size: 28rpx;
  color: #666;
}
.tab.active {
  color: #c96342;
  font-weight: 600;
  border-bottom: 4rpx solid #c96342;
}

/* date picker */
.date-picker {
  padding: 8rpx 24rpx;
  background: #f5f5f7;
  border-radius: 8rpx;
  font-size: 28rpx;
}

.section-title { font-size: 30rpx; font-weight: 600; }
.empty { padding: 32rpx; color: #999; text-align: center; font-size: 26rpx; }

.block {
  background: #fafafa;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.time {
  padding: 8rpx 20rpx;
  background: #fff;
  border-radius: 8rpx;
  border: 2rpx solid #e5e5e5;
  font-size: 26rpx;
}

.del { color: #999; font-size: 24rpx; padding: 8rpx 16rpx; }
.del.small { color: #c66; }

.task {
  background: #fff;
  padding: 16rpx;
  border-radius: 8rpx;
  margin-bottom: 12rpx;
}
.task-input {
  font-size: 26rpx;
  padding: 8rpx 0;
  border-bottom: 2rpx solid #f0f0f0;
}
.progress { flex: 1; margin-right: 16rpx; }

.btn.small { padding: 8rpx 20rpx; font-size: 24rpx; }
.btn-ghost.small { display: inline-block; }

.field { margin-bottom: 24rpx; }
.field .label { display: block; margin-bottom: 12rpx; }

.textarea, .input {
  width: 100%;
  background: #fafafa;
  border-radius: 8rpx;
  padding: 16rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  min-height: 60rpx;
}

.save-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  border-top: 2rpx solid #eee;
  padding: 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  z-index: 20;
}
.save-bar .status { font-size: 24rpx; }
.save-bar .btn { min-width: 200rpx; }

/* 日历 */
.cal-header {
  display: flex; align-items: center; justify-content: space-between;
  margin-bottom: 16rpx;
}
.cal-title { font-size: 30rpx; font-weight: 600; }
.cal-nav { font-size: 40rpx; color: #c96342; padding: 0 24rpx; }

.cal-week, .cal-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
}
.cal-w { text-align: center; padding: 12rpx 0; color: #999; font-size: 24rpx; }
.cal-cell {
  position: relative;
  aspect-ratio: 1;
  display: flex; align-items: center; justify-content: center;
  font-size: 28rpx;
  color: #333;
}
.cal-cell.empty { color: transparent; }
.cal-cell.today { background: #fff3ee; color: #c96342; border-radius: 50%; }
.dot {
  position: absolute;
  bottom: 12rpx;
  width: 10rpx; height: 10rpx;
  border-radius: 50%;
  background: #c96342;
}

/* 周分析 */
.week-title { font-size: 28rpx; color: #666; margin-bottom: 24rpx; text-align: center; }
.week-stat { display: flex; }
.stat { flex: 1; text-align: center; }
.stat-num { font-size: 48rpx; font-weight: 600; color: #c96342; }
.stat-label { font-size: 24rpx; color: #999; margin-top: 8rpx; }

.day-row {
  padding: 20rpx 0;
  border-bottom: 2rpx solid #f0f0f0;
}
.day-row:last-child { border-bottom: none; }
.day-head { display: flex; align-items: center; }
.day-label { width: 80rpx; color: #333; font-weight: 600; }
.day-date { color: #999; font-size: 24rpx; flex: 1; }
.day-hours { color: #c96342; font-weight: 600; }
.day-empty { color: #ccc; }
.day-tasks { margin-top: 12rpx; padding-left: 80rpx; }
.tag {
  display: inline-block;
  background: #fff3ee;
  color: #c96342;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  margin-right: 8rpx;
  margin-bottom: 8rpx;
}
