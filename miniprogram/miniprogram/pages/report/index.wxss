/* ══════════════════════════════════════════
   Report Page — Notion × Claude paper style
   ══════════════════════════════════════════ */

.page {
  padding-bottom: 60rpx;
  background: transparent;
}

/* ── Tab 栏（毛玻璃吸顶） ───────────────── */
.tabs {
  display: flex;
  position: sticky;
  top: 0;
  z-index: 100;
  background: rgba(232, 224, 216, 0.94);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-bottom: 1rpx solid rgba(180, 100, 60, 0.10);
}
.tab {
  flex: 1;
  text-align: center;
  padding: 28rpx 0 22rpx;
  font-size: 28rpx;
  color: #9b8070;
  position: relative;
  transition: color 0.25s ease, transform 0.15s ease;
}
.tab:active { transform: scale(0.92); }
.tab.active {
  color: #c96342;
  font-weight: 700;
}
.tab.active::after {
  content: '';
  position: absolute;
  bottom: 0; left: 18%; width: 64%;
  height: 4rpx;
  border-radius: 2rpx;
  background: linear-gradient(90deg, #c96342, #e8855a);
}

/* ── 日期卡 ───────────────────────────── */
.date-card { padding: 24rpx 36rpx; }
.date-pill {
  padding: 12rpx 28rpx;
  background: #fdf0eb;
  border-radius: 40rpx;
  border: 1rpx solid rgba(201, 99, 66, 0.25);
  color: #c96342;
  font-size: 28rpx;
  font-weight: 600;
  letter-spacing: 1rpx;
}

/* ── Section 标题 ─────────────────────── */
.section-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1a1208;
}

/* ── 空状态 ───────────────────────────── */
.empty-hint {
  padding: 36rpx;
  text-align: center;
  color: #c5a090;
  font-size: 26rpx;
}

/* ── 时段块 ───────────────────────────── */
.block-card {
  background: rgba(250, 240, 235, 0.45);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid rgba(201, 99, 66, 0.10);
  animation: fade-up 0.4s cubic-bezier(0.22, 0.8, 0.3, 1) both;
}

/* 时段时间 */
.time-pill {
  padding: 10rpx 22rpx;
  background: #fff;
  border-radius: 12rpx;
  border: 1rpx solid rgba(180, 100, 60, 0.18);
  font-size: 26rpx;
  color: #c96342;
  font-weight: 600;
}
.time-sep {
  color: #c5a090;
  font-size: 24rpx;
  margin: 0 4rpx;
}

/* 全完成 & 删除 */
.done-all-btn {
  font-size: 19rpx;
  color: #fff;
  background: linear-gradient(135deg, #3aa856, #5ec875);
  padding: 6rpx 14rpx;
  border-radius: 7rpx;
  font-weight: 600;
  box-shadow: 0 2rpx 6rpx rgba(58, 168, 86, 0.28);
  margin-top: 8rpx;
}
.done-all-btn:active { transform: scale(0.90); }
.del-btn {
  font-size: 22rpx;
  color: #e06060;
  padding: 8rpx 16rpx;
}

/* ── 任务行 ───────────────────────────── */
.task-row {
  display: flex;
  align-items: flex-start;
  margin-bottom: 16rpx;
  background: rgba(255, 255, 253, 0.80);
  border-radius: 12rpx;
  padding: 18rpx 16rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.90);
}

/* 完成圆圈 */
.task-check {
  width: 44rpx; height: 44rpx;
  min-width: 44rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(201, 99, 66, 0.35);
  margin-right: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
  margin-top: 4rpx;
}
.task-check.done {
  background: linear-gradient(135deg, #c96342, #e8855a);
  border-color: transparent;
  box-shadow: 0 2rpx 10rpx rgba(201, 99, 66, 0.35);
  animation: pop-in 0.25s ease;
}
.check-icon {
  color: #fff;
  font-size: 24rpx;
  font-weight: 700;
}

@keyframes pop-in {
  0%   { transform: scale(0.6); }
  70%  { transform: scale(1.15); }
  100% { transform: scale(1); }
}

.task-body { flex: 1; }

.task-input {
  font-size: 32rpx;
  color: #1a1208;
  padding: 10rpx 0;
  border-bottom: 1rpx solid rgba(180, 100, 60, 0.10);
  line-height: 1.5;
}
.task-input.done-text {
  color: #c5a090;
  text-decoration: line-through;
}

/* 进度滑块 */
.task-slider {
  flex: 1;
  margin: 0 8rpx 0 0 !important;
}
.progress-val {
  font-size: 22rpx;
  color: #c96342;
  font-weight: 600;
  min-width: 60rpx;
  text-align: right;
}
.del-sm {
  color: #e09090;
  font-size: 24rpx;
  padding: 0 0 0 16rpx;
}

.add-task-btn {
  font-size: 24rpx;
  color: #c96342;
  padding: 10rpx 4rpx;
  opacity: 0.75;
}
.add-task-btn:active { opacity: 1; }

/* ── 复盘区 ───────────────────────────── */
.field {
  margin-bottom: 28rpx;
}
.field .label {
  display: block;
  margin-bottom: 14rpx;
}
.textarea, .input {
  width: 100%;
  background: rgba(250, 240, 235, 0.50);
  border-radius: 14rpx;
  padding: 26rpx 24rpx;
  font-size: 32rpx;
  box-sizing: border-box;
  min-height: 88rpx;
  color: #1a1208;
  border: 1rpx solid rgba(201, 99, 66, 0.10);
  line-height: 1.6;
}
.textarea:focus, .input:focus {
  border-color: rgba(201, 99, 66, 0.30);
  background: rgba(255, 255, 253, 0.80);
}

/* ── 自动保存状态提示 ─────────────────── */
.autosave-pill {
  position: fixed;
  bottom: calc(40rpx + env(safe-area-inset-bottom));
  left: 50%;
  transform: translateX(-50%);
  background: rgba(26, 18, 8, 0.85);
  color: #fff;
  font-size: 24rpx;
  padding: 14rpx 34rpx;
  border-radius: 40rpx;
  z-index: 300;
  box-shadow: 0 6rpx 24rpx rgba(0, 0, 0, 0.22);
  animation: pill-in 0.3s ease both;
}
.autosave-ok { color: #7be0a0; }
@keyframes pill-in {
  from { opacity: 0; transform: translateX(-50%) translateY(20rpx); }
  to   { opacity: 1; transform: translateX(-50%) translateY(0); }
}

/* ── 日历 ─────────────────────────────── */
.cal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}
.cal-title { font-size: 30rpx; font-weight: 700; }
.cal-nav {
  font-size: 44rpx;
  color: #c96342;
  padding: 0 24rpx;
  line-height: 1;
}
.cal-nav:active { opacity: 0.6; }

.cal-week, .cal-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
}
.cal-w {
  text-align: center;
  padding: 12rpx 0;
  color: #9b8070;
  font-size: 22rpx;
  font-weight: 600;
  letter-spacing: 1rpx;
}
.cal-cell {
  position: relative;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #1a1208;
}
.cal-cell.empty { color: transparent; }
.cal-cell.today {
  background: #fdf0eb;
  color: #c96342;
  border-radius: 50%;
  font-weight: 700;
  box-shadow: 0 2rpx 10rpx rgba(201, 99, 66, 0.20);
}
.cal-cell:active { opacity: 0.6; }
.cal-dot {
  position: absolute;
  bottom: 8rpx;
  width: 10rpx; height: 10rpx;
  border-radius: 50%;
  background: #c96342;
}

.cal-hint {
  margin: -4rpx 24rpx 24rpx;
  padding: 16rpx 20rpx;
  background: #fdf0eb;
  border-radius: 12rpx;
  color: #c96342;
  font-size: 24rpx;
  text-align: center;
  border: 1rpx solid rgba(201, 99, 66, 0.15);
}

/* ── 周分析 ───────────────────────────── */
.stat-card { background: linear-gradient(135deg, rgba(255,253,250,0.95), rgba(253,240,235,0.90)); }

.week-range {
  font-size: 24rpx;
  color: #9b8070;
  text-align: center;
  margin-bottom: 24rpx;
  letter-spacing: 1rpx;
}
.week-stat-row {
  display: flex;
  align-items: center;
  margin-bottom: 32rpx;
}
.stat-box {
  flex: 1;
  text-align: center;
}
.stat-num {
  font-size: 56rpx;
  font-weight: 800;
  color: #c96342;
  line-height: 1.1;
  letter-spacing: -1rpx;
}
.stat-lbl {
  font-size: 22rpx;
  color: #9b8070;
  margin-top: 8rpx;
  letter-spacing: 1rpx;
}
.stat-divider {
  width: 1rpx;
  height: 80rpx;
  background: rgba(201, 99, 66, 0.15);
}

/* AI 分析按钮组（周报/月报 同款大按钮） */
.ai-btn-row {
  display: flex;
  gap: 18rpx;
}
.ai-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #c96342, #e8855a);
  color: #fff;
  font-weight: 700;
  box-shadow: 0 8rpx 24rpx rgba(201, 99, 66, 0.34);
  letter-spacing: 1rpx;
}
.ai-btn-big {
  padding: 38rpx 0;
  font-size: 30rpx;
}
.ai-btn:active { transform: scale(0.95); box-shadow: 0 4rpx 14rpx rgba(201, 99, 66, 0.24); }
.ai-btn.loading { opacity: 0.7; }
.ai-icon { font-size: 44rpx; }

/* 日详情行 */
.day-row {
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(180, 100, 60, 0.08);
}
.day-row:last-child { border-bottom: none; }
.day-row.has-data { }
.day-row:active { opacity: 0.7; }

.day-head {
  display: flex;
  align-items: center;
}
.day-lbl {
  width: 80rpx;
  color: #1a1208;
  font-weight: 700;
  font-size: 28rpx;
}
.day-date { color: #9b8070; font-size: 24rpx; flex: 1; }
.day-hrs  { color: #c96342; font-weight: 700; font-size: 28rpx; }
.day-empty { color: #d4bbb0; }

.day-tasks {
  margin-top: 12rpx;
  padding-left: 80rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

/* ══════════════ AI 分析弹窗 ══════════════ */
.modal-overlay {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(26, 18, 8, 0.55);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  z-index: 999;
  display: flex;
  align-items: flex-end;
}

.modal-card {
  width: 100%;
  max-height: 82vh;
  background: rgba(255, 255, 253, 0.97);
  border-radius: 32rpx 32rpx 0 0;
  padding: 0 0 env(safe-area-inset-bottom);
  display: flex;
  flex-direction: column;
  box-shadow: 0 -8rpx 60rpx rgba(0, 0, 0, 0.18);
  animation: slide-up 0.35s cubic-bezier(0.25, 0.8, 0.25, 1) both;
}

@keyframes slide-up {
  from { transform: translateY(100%); }
  to   { transform: translateY(0); }
}

.modal-handle {
  width: 80rpx; height: 8rpx;
  background: rgba(180, 100, 60, 0.20);
  border-radius: 4rpx;
  margin: 20rpx auto 0;
}
.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 36rpx 12rpx;
}
.modal-title {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 32rpx;
  font-weight: 700;
  color: #1a1208;
}
.modal-icon { font-size: 36rpx; }
.modal-close {
  width: 56rpx; height: 56rpx;
  border-radius: 50%;
  background: rgba(180, 100, 60, 0.10);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #9b8070;
}
.modal-close:active { background: rgba(180, 100, 60, 0.20); }

.modal-range {
  padding: 0 36rpx 20rpx;
  font-size: 22rpx;
  color: #9b8070;
  border-bottom: 1rpx solid rgba(180, 100, 60, 0.08);
}

/* 加载中 */
.modal-loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
  gap: 24rpx;
}
.loading-dots { display: flex; gap: 12rpx; }
.ld {
  width: 16rpx; height: 16rpx;
  border-radius: 50%;
  background: rgba(201, 99, 66, 0.70);
}
.ld1 { animation: blink-ld 1.3s ease-in-out infinite; }
.ld2 { animation: blink-ld 1.3s ease-in-out 0.2s infinite; }
.ld3 { animation: blink-ld 1.3s ease-in-out 0.4s infinite; }
@keyframes blink-ld {
  0%, 80%, 100% { opacity: 0.2; transform: scale(0.75); }
  40%            { opacity: 1;   transform: scale(1.25); }
}
.loading-txt {
  font-size: 26rpx;
  color: #9b8070;
}

/* 结果文字 */
.modal-body {
  flex: 1;
  max-height: 55vh;
  padding: 24rpx 36rpx;
}
.analysis-text {
  font-size: 28rpx;
  color: #1a1208;
  line-height: 1.8;
  white-space: pre-wrap;
  word-break: break-word;
}

/* 底部操作 */
.modal-footer {
  padding: 20rpx 36rpx 28rpx;
  border-top: 1rpx solid rgba(180, 100, 60, 0.08);
}
.modal-copy-btn {
  width: 100%;
  padding: 24rpx;
  font-size: 30rpx;
  letter-spacing: 2rpx;
  border-radius: 20rpx;
}

/* ── 生成汇报按钮 ─────────────────────── */
.gen-report-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  margin: 8rpx 24rpx 24rpx;
  padding: 26rpx 0;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #c96342 0%, #e8855a 100%);
  color: #fff;
  font-size: 28rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  box-shadow: 0 6rpx 22rpx rgba(201, 99, 66, 0.32);
}
.gen-report-icon { font-size: 32rpx; }
.gen-report-hover {
  transform: scale(0.96);
  box-shadow: 0 3rpx 12rpx rgba(201, 99, 66, 0.24);
}

/* ── 汇报双栏预览 ─────────────────────── */
.report-modal-body { padding: 8rpx 0 12rpx; }

.report-block {
  margin: 12rpx 24rpx 16rpx;
  background: rgba(255, 255, 253, 0.92);
  border-radius: 20rpx;
  padding: 24rpx;
  border: 1rpx solid rgba(201, 99, 66, 0.10);
  box-shadow: 0 4rpx 20rpx rgba(180, 100, 60, 0.08);
}
.report-block-hd {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 14rpx;
}
.report-block-title {
  display: flex;
  align-items: center;
  gap: 10rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #1a1208;
}
.report-block-icon { font-size: 30rpx; }
.report-block-tag {
  font-size: 20rpx;
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
  background: rgba(201, 99, 66, 0.12);
  color: #c96342;
  font-weight: 600;
}
.report-block-tag.green {
  background: rgba(58, 168, 86, 0.14);
  color: #3aa856;
}
.report-preview {
  background: rgba(250, 240, 235, 0.45);
  border-radius: 14rpx;
  border: 1rpx solid rgba(201, 99, 66, 0.08);
  padding: 20rpx;
  box-sizing: border-box;
  max-height: 320rpx;
}
.report-text {
  font-size: 26rpx;
  color: #1a1208;
  line-height: 1.85;
  white-space: pre-wrap;
  word-break: break-word;
  font-family: -apple-system, 'PingFang SC', monospace;
}
.report-copy-btn {
  width: 100%;
  box-sizing: border-box;
  margin-top: 16rpx;
  padding: 18rpx;
  font-size: 26rpx;
  letter-spacing: 1rpx;
  border-radius: 14rpx;
}
