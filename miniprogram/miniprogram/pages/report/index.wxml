<view class="page">

  <!-- ── Tab 栏（毛玻璃吸顶） ── -->
  <view class="tabs">
    <view class="tab {{tab==='edit'?'active':''}}" data-tab="edit" bindtap="switchTab">填写</view>
    <view class="tab {{tab==='calendar'?'active':''}}" data-tab="calendar" bindtap="switchTab">日历</view>
    <view class="tab {{tab==='week'?'active':''}}" data-tab="week" bindtap="switchTab">周分析</view>
  </view>

  <!-- ═══════════════════ 填写 Tab ═══════════════════ -->
  <block wx:if="{{tab==='edit'}}">

    <!-- 日期选择 -->
    <view class="card date-card">
      <view class="row" style="justify-content:space-between;align-items:center">
        <view class="row" style="gap:12rpx">
          <text style="font-size:32rpx">📅</text>
          <text class="label">日期</text>
        </view>
        <picker mode="date" value="{{date}}" bindchange="pickDate">
          <view class="date-pill">{{date}}</view>
        </picker>
      </view>
    </view>

    <!-- 时段任务 -->
    <view class="card">
      <view class="row" style="justify-content:space-between;margin-bottom:24rpx">
        <view class="row" style="gap:10rpx">
          <text style="font-size:30rpx">⏱</text>
          <text class="section-title">时段任务</text>
        </view>
        <view class="btn btn-ghost btn-sm" bindtap="addBlock">+ 新时段</view>
      </view>

      <view wx:if="{{blocks.length===0}}" class="empty-hint">
        <text>暂无时段，点击「+ 新时段」开始记录</text>
      </view>

      <block wx:for="{{blocks}}" wx:for-item="blk" wx:for-index="i" wx:key="i">
        <view class="block-card">
          <!-- 时段头 -->
          <view class="row" style="justify-content:space-between;margin-bottom:16rpx">
            <view class="row" style="gap:12rpx">
              <picker mode="time" value="{{blk.start}}" data-i="{{i}}" data-field="start" bindchange="onTimeChange">
                <view class="time-pill">{{blk.start||'开始'}}</view>
              </picker>
              <text class="time-sep">~</text>
              <picker mode="time" value="{{blk.end}}" data-i="{{i}}" data-field="end" bindchange="onTimeChange">
                <view class="time-pill">{{blk.end||'结束'}}</view>
              </picker>
            </view>
            <view class="row" style="gap:16rpx">
              <view class="done-all-btn" data-i="{{i}}" bindtap="blockAllDone">全完成</view>
              <view class="del-btn" data-i="{{i}}" bindtap="removeBlock">删除</view>
            </view>
          </view>

          <!-- 任务列表 -->
          <block wx:for="{{blk.tasks}}" wx:for-item="task" wx:for-index="j" wx:key="j">
            <view class="task-row">
              <!-- 完成圆圈 -->
              <view class="task-check {{task.progress>=100?'done':''}}"
                data-i="{{i}}" data-j="{{j}}" bindtap="onTaskDone">
                <text wx:if="{{task.progress>=100}}" class="check-icon">✓</text>
              </view>
              <view class="task-body">
                <input class="task-input {{task.progress>=100?'done-text':''}}"
                  placeholder="任务描述"
                  value="{{task.desc}}"
                  data-i="{{i}}" data-j="{{j}}"
                  bindinput="onTaskInput" />
                <view class="row" style="justify-content:space-between;margin-top:10rpx;align-items:center">
                  <view class="progress-track">
                    <view class="progress-fill" style="width:{{task.progress}}%"></view>
                  </view>
                  <view class="progress-val">{{task.progress}}%</view>
                  <view class="del-sm" data-i="{{i}}" data-j="{{j}}" bindtap="removeTask">✕</view>
                </view>
              </view>
            </view>
          </block>

          <view class="add-task-btn" data-i="{{i}}" bindtap="addTask">+ 添加任务</view>
        </view>
      </block>
    </view>

    <!-- 复盘区 -->
    <view class="card">
      <view class="row" style="gap:10rpx;margin-bottom:28rpx">
        <text style="font-size:30rpx">💡</text>
        <text class="section-title">日报复盘</text>
      </view>
      <view class="field">
        <text class="label">行得通的是</text>
        <textarea class="textarea" placeholder="今天哪些方法有效？" value="{{works}}"
          data-field="works" bindinput="onTextInput" auto-height />
      </view>
      <view class="field">
        <text class="label">行不通的是</text>
        <textarea class="textarea" placeholder="遇到了哪些阻碍？" value="{{not_works}}"
          data-field="not_works" bindinput="onTextInput" auto-height />
      </view>
      <view class="field">
        <text class="label">明日计划</text>
        <textarea class="textarea" placeholder="明天要做什么？" value="{{plans}}"
          data-field="plans" bindinput="onTextInput" auto-height />
      </view>
      <view class="field" style="margin-bottom:0">
        <text class="label">结语</text>
        <input class="input" placeholder="今日一句话" value="{{commit_text}}"
          data-field="commit_text" bindinput="onTextInput" />
      </view>
    </view>

    <!-- 保存栏（毛玻璃） -->
    <view class="save-bar">
      <view class="save-status">
        <text wx:if="{{isDirty}}" class="status-dirty">● 未保存</text>
        <text wx:elif="{{updatedAt}}" class="status-ok">✓ 已保存</text>
        <text wx:else class="status-idle">—</text>
      </view>
      <view class="save-actions">
        <view class="btn btn-ghost btn-sm all-done-btn {{allDone?'glowing':''}}"
          bindtap="onAllDone">一键完成</view>
        <button class="btn btn-sm" disabled="{{isSaving}}" bindtap="onSave">
          {{isSaving?'保存中...':'保存'}}
        </button>
      </view>
    </view>

  </block>

  <!-- ═══════════════════ 日历 Tab ═══════════════════ -->
  <block wx:if="{{tab==='calendar'}}">
    <view class="card">
      <view class="cal-header">
        <view class="cal-nav" bindtap="prevMonth">‹</view>
        <view class="cal-title">{{calYear}} 年 {{calMonth}} 月</view>
        <view class="cal-nav" bindtap="nextMonth">›</view>
      </view>
      <view class="cal-week">
        <view class="cal-w">一</view><view class="cal-w">二</view><view class="cal-w">三</view>
        <view class="cal-w">四</view><view class="cal-w">五</view><view class="cal-w">六</view><view class="cal-w">日</view>
      </view>
      <view class="cal-grid">
        <block wx:for="{{calCells}}" wx:key="index">
          <view wx:if="{{item.empty}}" class="cal-cell empty"></view>
          <view wx:else class="cal-cell {{item.isToday?'today':''}}"
            data-date="{{item.dateStr}}" bindtap="pickCell">
            <text>{{item.day}}</text>
            <view wx:if="{{item.hasReport}}" class="cal-dot"></view>
          </view>
        </block>
      </view>
    </view>
    <view class="cal-hint">● 红点表示当天有日报 · 点击查看/编辑</view>
  </block>

  <!-- ═══════════════════ 周分析 Tab ═══════════════════ -->
  <block wx:if="{{tab==='week'}}">

    <view wx:if="{{weekData}}" class="card stat-card">
      <view class="week-range">{{weekData.week_start}} ～ {{weekData.week_end}}</view>
      <view class="week-stat-row">
        <view class="stat-box">
          <view class="stat-num">{{weekData.total_hours}}</view>
          <view class="stat-lbl">总小时</view>
        </view>
        <view class="stat-divider"></view>
        <view class="stat-box">
          <view class="stat-num">{{weekData.completed_count}}</view>
          <view class="stat-lbl">完成任务</view>
        </view>
      </view>

      <!-- AI 分析按钮 -->
      <view class="ai-btn-row">
        <view class="ai-btn {{analysisLoading?'loading':''}}"
          data-type="week" bindtap="onAnalysis">
          <text class="ai-icon">🤖</text>
          <text>{{analysisLoading&&analysisType==='week'?'AI 分析中...':'AI 智析周报'}}</text>
        </view>
        <view class="ai-btn ai-btn-secondary"
          data-type="month" bindtap="onAnalysis">
          <text class="ai-icon">📊</text>
          <text>{{analysisLoading&&analysisType==='month'?'月报分析中...':'月报分析'}}</text>
        </view>
      </view>
    </view>

    <view wx:if="{{weekData}}" class="card">
      <block wx:for="{{weekData.days}}" wx:key="date">
        <view class="day-row {{item.has_report?'has-data':''}}"
          data-date="{{item.date}}" bindtap="weekDayTap">
          <view class="day-head">
            <text class="day-lbl">周{{item.weekday}}</text>
            <text class="day-date">{{item.date}}</text>
            <text class="day-hrs" wx:if="{{item.has_report}}">{{item.hours}}h</text>
            <text class="day-empty" wx:else>—</text>
          </view>
          <view wx:if="{{item.completed_tasks.length}}" class="day-tasks">
            <text wx:for="{{item.completed_tasks}}" wx:for-item="t" wx:key="*this"
              class="chip">{{t}}</text>
          </view>
        </view>
      </block>
    </view>

    <view wx:if="{{!weekData}}" class="card empty-hint">
      <text>本周暂无日报数据</text>
    </view>

  </block>

</view>

<!-- ═══════════ AI 分析弹窗（全局浮层） ═══════════ -->
<view wx:if="{{showModal}}" class="modal-overlay" bindtap="closeModal">
  <view class="modal-card" catchtap="">
    <view class="modal-handle"></view>
    <view class="modal-header">
      <view class="modal-title">
        <text class="modal-icon">🤖</text>
        <text>{{analysisType==='week'?'AI 周报分析':'AI 月报分析'}}</text>
      </view>
      <view class="modal-close" bindtap="closeModal">✕</view>
    </view>
    <view class="modal-range">{{analysisRange}}</view>

    <!-- 加载中 -->
    <view wx:if="{{analysisLoading}}" class="modal-loading">
      <view class="loading-dots">
        <view class="ld ld1"></view>
        <view class="ld ld2"></view>
        <view class="ld ld3"></view>
      </view>
      <text class="loading-txt">AI 正在思考，稍候片刻...</text>
    </view>

    <!-- 结果 -->
    <scroll-view wx:if="{{!analysisLoading}}" scroll-y class="modal-body">
      <text class="analysis-text">{{analysisText}}</text>
    </scroll-view>

    <!-- 底部操作 -->
    <view wx:if="{{!analysisLoading}}" class="modal-footer">
      <view class="btn modal-copy-btn" bindtap="copyAnalysis">
        <text>{{copied?'✓ 已复制':'一键复制'}}</text>
      </view>
    </view>
  </view>
</view>
