/* ===== 工具/同步页 ===== */
.page {
  min-height: 100vh;
  padding-bottom: 20rpx;
}

/* ─── 顶部栏 ─── */
.top-bar {
  padding: 32rpx 32rpx 16rpx;
  background: var(--color-card);
}
.top-bar-title {
  font-size: 40rpx;
  font-weight: 800;
  color: var(--color-text);
  display: block;
}
.top-bar-sub {
  font-size: 22rpx;
  color: var(--color-text-tertiary);
  margin-top: 4rpx;
  display: block;
}

/* ─── 卡片覆盖 ─── */
.card {
  background: var(--color-card);
  margin: var(--space-md);
  border-radius: var(--radius-lg);
  padding: var(--space-xl);
  box-shadow: var(--shadow-sm);
}

/* ═══ 同步区 ═══ */
.sync-card {
  padding-bottom: var(--space-lg);
}
.sync-header {
  margin-bottom: var(--space-lg);
}
.sync-header-left {
  display: flex;
  align-items: center;
  gap: var(--space-md);
}
.sync-icon-box {
  width: 72rpx;
  height: 72rpx;
  border-radius: var(--radius-md);
  background: var(--color-primary-light);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.sync-icon-symbol {
  font-size: 36rpx;
  color: var(--color-primary);
  font-weight: 700;
}
.sync-header-info {
  flex: 1;
}
.sync-header-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-text);
  display: block;
}
.sync-header-desc {
  font-size: 22rpx;
  color: var(--color-text-tertiary);
  margin-top: 2rpx;
  display: block;
}

/* 上次同步 */
.sync-time-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--space-md) 0;
  border-top: 1rpx solid var(--color-border);
  margin-top: var(--space-sm);
}
.sync-time-label {
  font-size: 24rpx;
  color: var(--color-text-tertiary);
}
.sync-time-val {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  font-weight: 500;
}

/* 自动同步开关 */
.sync-auto-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--space-md) 0;
  border-top: 1rpx solid var(--color-border);
}
.sync-auto-info {
  flex: 1;
}
.sync-auto-label {
  font-size: 26rpx;
  color: var(--color-text);
  font-weight: 500;
  display: block;
}
.sync-auto-desc {
  font-size: 20rpx;
  color: var(--color-text-tertiary);
  margin-top: 2rpx;
  display: block;
}
.sync-auto-switch {
  flex-shrink: 0;
}

/* 同步结果 */
.sync-result {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
  padding: var(--space-sm) var(--space-md);
  border-radius: var(--radius-sm);
  margin: var(--space-sm) 0;
  font-size: 24rpx;
}
.sync-result.success {
  background: var(--color-success-light);
}
.sync-result.error {
  background: var(--color-danger-light);
}
.sync-result-icon {
  font-size: 26rpx;
  font-weight: 700;
}
.sync-result.success .sync-result-icon {
  color: var(--color-success);
}
.sync-result.error .sync-result-icon {
  color: var(--color-danger);
}
.sync-result-msg {
  color: var(--color-text-secondary);
  flex: 1;
}

/* 同步按钮 */
.sync-btn-wrap {
  margin-top: var(--space-lg);
}
.sync-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: var(--space-md);
  height: 96rpx;
  border-radius: 48rpx;
  background: linear-gradient(135deg, #2563eb 0%, #1d4ed8 100%);
  box-shadow: 0 8rpx 24rpx rgba(37, 99, 235, 0.3);
  transition: all 0.25s;
}
.sync-btn:active {
  transform: scale(0.97);
  opacity: 0.9;
  box-shadow: 0 4rpx 12rpx rgba(37, 99, 235, 0.25);
}
.sync-btn-disabled {
  opacity: 0.5;
  pointer-events: none;
}
.sync-btn-icon-wrap {
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.sync-btn-spin {
  animation: spin 1s linear infinite;
}
.sync-btn-icon-text {
  font-size: 38rpx;
  color: #fff;
  font-weight: 700;
}
.sync-btn-text {
  font-size: 30rpx;
  color: #fff;
  font-weight: 600;
  letter-spacing: 2rpx;
}
@keyframes spin {
  to { transform: rotate(360deg); }
}

/* ═══ 同步日志 ═══ */
.log-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--space-lg);
}
.log-header-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text);
}
.log-header-clear {
  font-size: 24rpx;
  color: var(--color-text-tertiary);
  padding: 4rpx 12rpx;
}
.log-header-clear:active {
  opacity: 0.6;
}
.log-item {
  display: flex;
  align-items: flex-start;
  gap: var(--space-md);
  padding: var(--space-sm) 0;
  border-bottom: 1rpx solid var(--color-border);
}
.log-item:last-child {
  border-bottom: none;
}
.log-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  flex-shrink: 0;
  margin-top: 8rpx;
}
.log-dot-success {
  background: var(--color-success);
}
.log-dot-error {
  background: var(--color-danger);
}
.log-info {
  flex: 1;
}
.log-time {
  font-size: 22rpx;
  color: var(--color-text-tertiary);
  display: block;
  margin-bottom: 2rpx;
}
.log-msg {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  display: block;
  line-height: 1.5;
}

/* ═══ 系统状态 ═══ */
.status-header {
  margin-bottom: var(--space-lg);
}
.status-header-left {
  display: flex;
  align-items: center;
  gap: var(--space-md);
}
.status-icon-box {
  width: 72rpx;
  height: 72rpx;
  border-radius: var(--radius-md);
  background: var(--color-success-light);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.status-icon-symbol {
  font-size: 36rpx;
  color: var(--color-success);
  font-weight: 700;
}
.status-header-info {
  flex: 1;
}
.status-header-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-text);
  display: block;
}
.status-header-desc {
  font-size: 22rpx;
  color: var(--color-text-tertiary);
  margin-top: 2rpx;
  display: block;
}

/* 状态列表 */
.status-list {
  margin-bottom: var(--space-md);
}
.status-item {
  display: flex;
  align-items: center;
  padding: var(--space-md) 0;
  border-bottom: 1rpx solid var(--color-border);
}
.status-item:last-child {
  border-bottom: none;
}
.s-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  margin-right: var(--space-md);
  flex-shrink: 0;
}
.s-dot-green {
  background: var(--color-success);
  box-shadow: 0 0 6rpx var(--color-success);
}
.s-dot-red {
  background: var(--color-danger);
}
.s-dot-yellow {
  background: var(--color-warning);
  animation: pulse 1s ease-in-out infinite;
}
@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.4; }
}
.s-name {
  flex: 1;
  font-size: 26rpx;
  color: var(--color-text-secondary);
}
.s-val {
  font-size: 24rpx;
  font-weight: 500;
}

/* 重新检测 */
.status-check {
  display: flex;
  justify-content: center;
  padding: var(--space-md);
  background: var(--color-bg);
  border-radius: var(--radius-md);
}
.status-check:active {
  opacity: 0.7;
}
.status-check-text {
  font-size: 26rpx;
  color: var(--color-primary);
  font-weight: 600;
}

/* ═══ 快捷工具 ═══ */
.tool-header {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text);
  margin-bottom: var(--space-sm);
}
.tool-item {
  display: flex;
  align-items: center;
  gap: var(--space-md);
  padding: var(--space-md) 0;
}
.tool-item:active {
  opacity: 0.7;
}
.tool-icon-box {
  width: 60rpx;
  height: 60rpx;
  border-radius: var(--radius-sm);
  background: var(--color-bg);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.tool-icon-symbol {
  font-size: 28rpx;
  color: var(--color-text-tertiary);
  font-weight: 700;
}
.tool-info {
  flex: 1;
}
.tool-name {
  font-size: 26rpx;
  color: var(--color-text);
  display: block;
  font-weight: 500;
}
.tool-sub {
  font-size: 20rpx;
  color: var(--color-text-tertiary);
  margin-top: 2rpx;
  display: block;
}
.tool-arrow {
  font-size: 28rpx;
  color: var(--color-text-tertiary);
}

/* ═══ 关于 ═══ */
.about-area {
  text-align: center;
  padding: 48rpx 40rpx 32rpx;
}
.about-name {
  display: block;
  font-size: 26rpx;
  color: var(--color-text-tertiary);
  font-weight: 500;
}
.about-desc {
  display: block;
  font-size: 22rpx;
  color: var(--color-text-tertiary);
  margin-top: 6rpx;
}
.about-version {
  display: block;
  font-size: 20rpx;
  color: var(--color-border);
  margin-top: 6rpx;
}
