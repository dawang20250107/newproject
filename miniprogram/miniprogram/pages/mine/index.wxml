<view class="page">

  <!-- ─── 顶部栏 ─── -->
  <view class="top-bar">
    <text class="top-bar-title">数据同步</text>
    <text class="top-bar-sub">KXT 数据管理控制台</text>
  </view>

  <!-- ─── 同步操作区 ─── -->
  <view class="card sync-card">
    <view class="sync-header">
      <view class="sync-header-left">
        <view class="sync-icon-box">
          <text class="sync-icon-symbol">↻</text>
        </view>
        <view class="sync-header-info">
          <text class="sync-header-title">同步腾讯文档</text>
          <text class="sync-header-desc">将腾讯文档最新数据拉取至服务器</text>
        </view>
      </view>
    </view>

    <!-- 上次同步时间 -->
    <view class="sync-time-row" wx:if="{{lastSyncTime}}">
      <text class="sync-time-label">上次同步</text>
      <text class="sync-time-val">{{lastSyncTime}}</text>
    </view>

    <!-- 自动同步开关 -->
    <view class="sync-auto-row">
      <view class="sync-auto-info">
        <text class="sync-auto-label">每小时自动同步</text>
        <text class="sync-auto-desc">{{autoSyncEnabled ? '已开启，每小时自动执行' : '关闭'}}</text>
      </view>
      <switch class="sync-auto-switch" checked="{{autoSyncEnabled}}" color="#2563eb" bindchange="onToggleAutoSync"/>
    </view>

    <!-- 同步结果提示 -->
    <view class="sync-result {{syncResult.type}}" wx:if="{{syncResult.msg}}">
      <text class="sync-result-icon">{{syncResult.type === 'success' ? '✓' : '✕'}}</text>
      <text class="sync-result-msg">{{syncResult.msg}}</text>
    </view>

    <!-- 手动同步按钮 -->
    <view class="sync-btn-wrap">
      <view class="sync-btn {{syncing ? 'sync-btn-disabled' : ''}}" bindtap="onManualSync">
        <view class="sync-btn-icon-wrap {{syncing ? 'sync-btn-spin' : ''}}">
          <text class="sync-btn-icon-text">↻</text>
        </view>
        <text class="sync-btn-text">{{syncing ? '同步中...' : '立即同步'}}</text>
      </view>
    </view>
  </view>

  <!-- ─── 同步日志 ─── -->
  <view class="card" wx:if="{{syncLogs.length > 0}}">
    <view class="log-header">
      <text class="log-header-title">同步日志</text>
      <text class="log-header-clear" bindtap="onClearLogs">清除</text>
    </view>
    <view wx:for="{{syncLogs}}" wx:key="time" class="log-item">
      <view class="log-dot {{item.status === 'success' ? 'log-dot-success' : 'log-dot-error'}}"></view>
      <view class="log-info">
        <text class="log-time">{{item.time}}</text>
        <text class="log-msg">{{item.msg}}</text>
      </view>
    </view>
  </view>

  <!-- ─── 快捷工具 ─── -->
  <view class="card">
    <view class="tool-header">快捷工具</view>
    <view class="tool-item" bindtap="onCopyApiUrl">
      <view class="tool-icon-box">
        <text class="tool-icon-symbol">⋮</text>
      </view>
      <view class="tool-info">
        <text class="tool-name">复制 API 地址</text>
        <text class="tool-sub">https://kxtshare.cloud</text>
      </view>
      <text class="tool-arrow">→</text>
    </view>
  </view>

  <!-- ─── 关于 ─── -->
  <view class="about-area">
    <text class="about-name">KXT 应收账款管理系统</text>
    <text class="about-desc">劳务事业部 · 内部数据管理工具</text>
    <text class="about-version">v2.0.0</text>
  </view>

  <view class="safe-bottom"></view>
</view>
