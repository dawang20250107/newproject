/* ══════════════════════════════════════════
   KXT 日报 — 全局样式
   Palette: warm cream + terracotta + frosted glass
   Style: Notion × Claude paper
   ══════════════════════════════════════════ */

page {
  background: #faf7f4;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', sans-serif;
  font-size: 28rpx;
  color: #1a1208;
  -webkit-font-smoothing: antialiased;
}

/* ── 卡片（毛玻璃） ───────────────────── */
.card {
  background: rgba(255, 255, 253, 0.93);
  /* backdrop-filter not supported in WXSS */
  border-radius: 24rpx;
  padding: 36rpx;
  margin: 20rpx 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.85);
  box-shadow:
    0 4rpx 24rpx rgba(180, 100, 60, 0.08),
    0 1rpx 4rpx  rgba(0, 0, 0, 0.04);
  animation: card-in 0.5s cubic-bezier(0.22, 0.85, 0.3, 1) both;
}

/* ── 进入动画 ─────────────────────────── */
@keyframes card-in {
  from { opacity: 0; transform: translateY(28rpx) scale(0.985); }
  to   { opacity: 1; transform: translateY(0) scale(1); }
}
.card:nth-child(1) { animation-delay: 0.02s; }
.card:nth-child(2) { animation-delay: 0.08s; }
.card:nth-child(3) { animation-delay: 0.14s; }
.card:nth-child(4) { animation-delay: 0.20s; }

@keyframes fade-up {
  from { opacity: 0; transform: translateY(20rpx); }
  to   { opacity: 1; transform: translateY(0); }
}
.fade-up { animation: fade-up 0.45s cubic-bezier(0.22, 0.8, 0.3, 1) both; }

/* ── 按钮系统 ─────────────────────────── */
.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx 40rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 600;
  background: linear-gradient(135deg, #c96342 0%, #e8855a 100%);
  color: #fff;
  border: none;
  box-shadow: 0 4rpx 18rpx rgba(201, 99, 66, 0.32);
  transition: all 0.15s ease;
  letter-spacing: 1rpx;
}
.btn:active {
  transform: scale(0.93);
  box-shadow: 0 2rpx 8rpx rgba(201, 99, 66, 0.20);
}
.btn[disabled] {
  background: linear-gradient(135deg, #d4b5a8, #dcc4ba);
  box-shadow: none;
  color: rgba(255, 255, 255, 0.75);
}

.btn-ghost {
  background: transparent;
  color: #c96342;
  border: 1.5rpx solid rgba(201, 99, 66, 0.45);
  box-shadow: none;
}
.btn-ghost:active {
  background: rgba(201, 99, 66, 0.06);
  box-shadow: none;
}

.btn-sm {
  padding: 10rpx 24rpx;
  font-size: 24rpx;
  border-radius: 10rpx;
}

/* ── 行布局 ───────────────────────────── */
.row {
  display: flex;
  align-items: center;
}

/* ── 文字标签 ─────────────────────────── */
.label {
  color: #9b7a6a;
  font-size: 22rpx;
  font-weight: 600;
  letter-spacing: 1.5rpx;
  text-transform: uppercase;
}

/* ── 分割线 ───────────────────────────── */
.divider {
  height: 1rpx;
  background: rgba(180, 100, 60, 0.08);
  margin: 16rpx 0;
}

/* ── 标签 chip ────────────────────────── */
.chip {
  display: inline-block;
  background: #fdf0eb;
  color: #c96342;
  padding: 6rpx 18rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: 500;
  border: 1rpx solid rgba(201, 99, 66, 0.18);
}
