page {
  background: #f5f5f7;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', sans-serif;
  font-size: 28rpx;
  color: #1d1d1f;
}

.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 32rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  background: #c96342;
  color: #fff;
  border: none;
}

.btn[disabled] {
  background: #bbb;
  color: #fff;
}

.btn-ghost {
  background: transparent;
  color: #c96342;
  border: 2rpx solid #c96342;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

.row {
  display: flex;
  align-items: center;
}

.label {
  color: #6e6e73;
  font-size: 26rpx;
}
